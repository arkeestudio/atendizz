# Modelo de variáveis de ambiente.
# Copie este arquivo para `.env` e preencha com os valores reais.
# O `.env` real NUNCA é commitado (está no .gitignore).

# --- Supabase (conexão com o banco) ---
SUPABASE_PROJECT_ID=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# --- Secrets de backend (só servidor; SEM prefixo VITE_) ---
EVOLUTION_API_URL=""
EVOLUTION_API_KEY=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Pagamento (Paddle) — separado por ambiente em .env.development / .env.production ---
VITE_PAYMENTS_CLIENT_TOKEN=""
